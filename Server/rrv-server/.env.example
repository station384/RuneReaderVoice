# RuneReader Voice Server — Environment Variables
# Copy to .env and edit as needed. All values shown are defaults.
# CLI flags (--flag value) take precedence over environment variables.

# ── Network ───────────────────────────────────────────────────────────────────

# Address to bind on. Use 0.0.0.0 to accept connections from all LAN clients.
RRV_HOST=0.0.0.0

# Port the server listens on.
RRV_PORT=8765

# ── Paths ─────────────────────────────────────────────────────────────────────

# Directory where generated OGG files are stored.
# In a container, mount a host volume here to persist the cache across restarts.
RRV_CACHE_DIR=../data/cache

# Path to the SQLite manifest database.
# In a container, keep this on the same volume as RRV_CACHE_DIR.
RRV_DB_PATH=../data/server-cache.db

# Directory containing TTS model files (kokoro-v1.0.onnx, model.pth, etc.)
# Can be shared with the RuneReader Voice C# client models/ directory.
# In a container, mount as read-only volume.
RRV_MODELS_DIR=../data/models

# Directory containing reference audio clips for voice matching (F5-TTS, Chatterbox Turbo).
# Files must use underscore/hyphen naming, no spaces. See SETUP.md for conventions.
# In a container, mount as read-only volume.
RRV_SAMPLES_DIR=../data/samples

# Directory containing the Whisper model for auto-transcribing reference audio samples.
# Only used when a voice-matching backend (f5tts, chatterbox) is loaded.
# The server NEVER downloads from HuggingFace — all model files must be pre-placed.
# Download from:
#   v3-turbo (~1.6 GB): https://huggingface.co/openai/whisper-large-v3-turbo
#   tiny     (~150 MB): https://huggingface.co/openai/whisper-tiny
# Recommended layout:
#   data/models/whisper/v3-turbo/   ← set this path for best accuracy
#   data/models/whisper/tiny/       ← set this path for fastest transcription
RRV_WHISPER_MODEL_DIR=../data/models/whisper/v3-turbo

# SQLite database for community NPC override crowd-source data.
RRV_COMMUNITY_DB_PATH=../data/community.db

# Directory for community seed data (voice profiles, pronunciation rules, etc.)
RRV_DEFAULTS_DIR=../data/defaults

# How often (in seconds) to scan the samples directory for new audio files
# that need transcription. Only active when a voice-matching backend is loaded.
RRV_SAMPLE_SCAN_INTERVAL=30

# ── Backends ──────────────────────────────────────────────────────────────────

# Comma-separated list of backends to load at startup.
# Valid values: kokoro, f5tts, chatterbox, chatterbox_full, chatterbox_multilingual
# Backends not listed are not loaded and will not appear in capability responses.
RRV_BACKENDS=kokoro

# ── GPU / Execution Provider ──────────────────────────────────────────────────

# GPU execution provider for inference.
# auto  — probe hardware at startup: CUDA → ROCm → CPU (recommended)
# cuda  — force CUDA (fails if CUDA not available)
# rocm  — force ROCm (fails if ROCm not available)
# cpu   — force CPU (always available, slower for F5-TTS/Chatterbox)
RRV_GPU=auto

# ── Cache ─────────────────────────────────────────────────────────────────────

# Maximum total size of cached OGG files in megabytes.
# LRU eviction removes least-recently-used files when the limit is exceeded.
RRV_CACHE_MAX_MB=2048

# ── Security ──────────────────────────────────────────────────────────────────

# API key for Bearer token authentication.
# Leave empty (default) to disable authentication entirely.
# When set, all endpoints require: Authorization: Bearer <key>
# This is a stub for LAN use — not a substitute for proper TLS in public deployments.
RRV_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: debug, info, warning, error
RRV_LOG_LEVEL=info

# ── Worker venvs (optional — for isolated subprocess backends) ────────────────
#
# Set RRV_WORKER_VENV_<backend> to the path of a dedicated venv for that backend.
# The backend will run as an isolated subprocess in that venv instead of being
# imported into the host process. This is the recommended way to run backends
# that have conflicting dependency versions (e.g. Chatterbox vs Qwen both pin
# different versions of transformers).
#
# If unset for a backend, it is loaded in-process as before (backward-compatible).
#
# Layout (relative to rrv-server/ where .env lives):
#   ../rrv-kokoro/.venv       ← kokoro-onnx, onnxruntime
#   ../rrv-chatterbox/.venv   ← chatterbox-tts, transformers==4.46.3
#   ../rrv-f5/.venv           ← f5-tts, transformers==4.46.3
#   ../rrv-qwen/.venv         ← qwen-tts, transformers==4.57.3
#
# RRV_WORKER_VENV_kokoro=../rrv-kokoro/.venv
# RRV_WORKER_VENV_chatterbox=../rrv-chatterbox/.venv
# RRV_WORKER_VENV_chatterbox_full=../rrv-chatterbox/.venv
# RRV_WORKER_VENV_chatterbox_multilingual=../rrv-chatterbox/.venv
# RRV_WORKER_VENV_f5tts=../rrv-f5/.venv
# RRV_WORKER_VENV_qwen_natural=../rrv-qwen/.venv
# RRV_WORKER_VENV_qwen_custom=../rrv-qwen/.venv
# RRV_WORKER_VENV_qwen_design=../rrv-qwen/.venv

# ── Qwen model configuration ──────────────────────────────────────────────────
# Which checkpoint size backs qwen_natural and qwen_custom: "large" (1.7B) or "small" (0.6B)
# qwen_design always uses the large (1.7B) checkpoint.
# RRV_QWEN_NATURAL_SIZE=large
# RRV_QWEN_CUSTOM_SIZE=large
# Root directory for Qwen model files (tokenizer, natural-large, custom-large, design, etc.)
# RRV_QWEN_MODELS_DIR=../data/models/qwen
# Enable torch.compile() for Qwen backends — reduces autoregressive loop overhead.
# One-time compilation cost on first synthesis (~30s). Opt-in due to cold-start cost.
# RRV_QWEN_COMPILE=false

# ── LuxTTS ──────────────────────────────────────────────────────────────────
# RRV_WORKER_VENV_lux=../rrv-lux/.venv
# RRV_LUX_SAMPLE_CHANNELS=1
# RRV_LUX_SAMPLE_RATE=48000
# ODE solver steps — higher = better quality. Default 10. Range 4-32.
# RRV_LUX_NUM_STEPS=10

# ── CosyVoice3 ───────────────────────────────────────────────────────────────
# RRV_WORKER_VENV_cosyvoice=../rrv-cosyvoice/.venv
# Path to the CosyVoice source repo for Matcha-TTS sys.path injection.
# RRV_COSYVOICE_SRC_DIR=/home/mike/rrvserver/rrv-cosyvoice/cosyvoice-src
