# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environments (all worker dirs + host) ─────────────────────────────
rrv-server/.venv/
rrv-kokoro/.venv/
rrv-chatterbox/.venv/
rrv-f5/.venv/
rrv-qwen/.venv/

# ── Live config (copied from .env.example, never committed) ───────────────────
rrv-server/.env

# ── Shared data (large binary files, generated at runtime) ───────────────────
# Stub placeholder files (MODELS.txt, SAMPLES.txt) ARE committed.
# Everything else in data/ is not.
data/cache/
data/models/*
data/samples/*
data/defaults/
data/server-cache.db
data/community.db

# Keep the stub placeholder files
!data/models/MODELS.txt
!data/samples/SAMPLES.txt

# ── Runtime / temp ────────────────────────────────────────────────────────────
/tmp/rrv_worker_*.sock
*.log

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
