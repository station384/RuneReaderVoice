<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="RuneReaderVoice.UI.Views.MainWindow"
        Title="RuneReader Voice"
        Width="600" 
        MinWidth="480" MinHeight="160"
        MaxHeight="900"
        SizeToContent="Height"
        Background="#1A1A2E">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" >

        <!-- ── Title bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" 
                Background="#16213E" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8" >
                <TextBlock Text="RuneReader Voice"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#E0E0FF" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusBadge"
                           Text="●  Idle"
                           FontSize="13" Foreground="#888"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Live status panel ──────────────────────────────────────── -->
        <Border Grid.Row="1" 
                Background="#0F3460" Margin="8,8,8,0"
                CornerRadius="6" Padding="12,10">
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">

                <!-- Capture status -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Capture" Foreground="#888" FontSize="11"/>
                <TextBlock x:Name="CaptureStatus" Grid.Row="0" Grid.Column="1"
                           Text="Stopped" Foreground="#FF6B6B" FontSize="11"/>

                <!-- Session status -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Session" Foreground="#888" FontSize="11" Margin="0,4,0,0"/>
                <TextBlock x:Name="SessionStatus" Grid.Row="1" Grid.Column="1"
                           Text="—" Foreground="#E0E0FF" FontSize="11" Margin="0,4,0,0"/>

                <!-- Playback state -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Playback" Foreground="#888" FontSize="11" Margin="0,4,0,0"/>
                <TextBlock x:Name="PlaybackStatus" Grid.Row="2" Grid.Column="1"
                           Text="Idle" Foreground="#4ECDC4" FontSize="11" Margin="0,4,0,0"/>

                <!-- Cache hit indicator -->
                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="Cache" Foreground="#888" FontSize="11" Margin="0,4,0,0"/>
                <TextBlock x:Name="CacheStatus" Grid.Row="3" Grid.Column="1"
                           Text="—" Foreground="#FFD166" FontSize="11" Margin="0,4,0,0"/>
            </Grid>
        </Border>


        <!-- ── Volume + Start/Stop row ──────────────────────────────────────── -->
        <Border Grid.Row="2" Margin="8,8,8,0">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="Vol" Foreground="#888" FontSize="11"
                           VerticalAlignment="Center"/>
                <Slider Grid.Column="1"
                        x:Name="VolumeSlider"
                        Minimum="0" Maximum="100" Value="80"
                        VerticalAlignment="Center"
                        ValueChanged="OnVolumeChanged"/>
                <TextBlock Grid.Column="2"
                           x:Name="VolumeLabel"
                           Text="80%" Foreground="#888" FontSize="11"
                           VerticalAlignment="Center" Width="34"/>
                <Button Grid.Column="3"
                        x:Name="StartStopButton"
                        Content="Start Capture"
                        Width="130" Height="36"
                        Background="#E94560"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Click="OnStartStopClicked"/>
            </Grid>
        </Border>

        <!-- ── Last NPC panel ─────────────────────────────────────────── -->
        <!-- Appears after each NPC dialog. Hidden for narrator/book (NpcId=0). -->
        <Border x:Name="LastNpcPanel"
                Grid.Row="3"
                IsVisible="False"
                Background="#1A2E1A" Margin="8,8,8,0"
                CornerRadius="6" Padding="10,8" >
            <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="8" RowSpacing="6">

                <!-- Row 0: NPC id label + notes box + Save + Clear -->
                <TextBlock x:Name="LastNpcIdLabel"
                           Grid.Row="0" Grid.Column="0"
                           Text="NPC ID: —"
                           Foreground="#4ECDC4" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBox x:Name="LastNpcNotesBox"
                         Grid.Row="0" Grid.Column="1"
                         Watermark="optional name / note (e.g. Thrall)"
                         FontSize="11" Background="Transparent" BorderBrush="#334"/>
                <Button x:Name="LastNpcSaveButton"
                        Grid.Row="0" Grid.Column="2"
                        Content="Save" FontSize="11"
                        Padding="10,3"
                        Click="OnLastNpcSaveClicked"/>
                <Button x:Name="LastNpcClearButton"
                        Grid.Row="0" Grid.Column="3"
                        Content="Clear" FontSize="11"
                        Padding="10,3" IsEnabled="False"
                        Background="#4A2020"
                        Click="OnLastNpcClearClicked"/>

                <!-- Row 1: race dropdown -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Voice accent" Foreground="#888" FontSize="10"
                           VerticalAlignment="Center"/>
                <ComboBox x:Name="LastNpcRaceDropdown"
                          Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                          FontSize="11" HorizontalAlignment="Stretch"/>

                <!-- Row 2: bespoke sample picker (hidden when no voice-matching provider active) -->
                <StackPanel x:Name="LastNpcSamplePanel"
                            Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                            Orientation="Horizontal" Spacing="8"
                            IsVisible="False">
                    <TextBlock Text="Bespoke sample" Foreground="#888" FontSize="10"
                               VerticalAlignment="Center" Width="90"
                               ToolTip.Tip="Override the reference voice sample for this specific NPC. Uses the race slot DSP and other settings — only the sample is replaced."/>
                    <ComboBox x:Name="LastNpcSampleDropdown"
                              FontSize="11" MinWidth="260" HorizontalAlignment="Stretch"/>
                </StackPanel>

            </Grid>
        </Border>


        <!-- ── Settings expander ──────────────────────────────────────── -->
        <Expander x:Name="ExpanderSettings"
                  Header="Settings"
                  Grid.Row="4"
                  IsExpanded="False"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Top" 
                  Margin="8,4,8,8">
            <TabControl
                        x:Name="SettingsTabControl"
                        Margin="0" 
                        Background="#16213E">

            <!-- Basic settings tab -->
            <TabItem Header="Settings" >
                <ScrollViewer>
                    <Grid Margin="12" ColumnDefinitions="*,*" ColumnSpacing="12">

                        <!-- LEFT: TTS Provider, Playback -->
                        <StackPanel Grid.Column="0" Spacing="6">

                            <Expander x:Name="ExpanderProvider"
                                      Header="TTS Provider"
                                      HorizontalAlignment="Stretch"
                                      IsExpanded="False">
                                <StackPanel Margin="0,8,0,0" Spacing="6">
                                    <ComboBox x:Name="ProviderSelector"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnProviderChanged"/>

                                    <TextBlock Text="Remote Server URL" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                                    <TextBox x:Name="RemoteServerUrl" TextChanged="OnRemoteServerUrlChanged"/>

                                    <TextBlock Text="Remote API Key (optional)" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                                    <TextBox x:Name="RemoteApiKey" TextChanged="OnRemoteApiKeyChanged" PasswordChar="*"/>

                                    <TextBlock Text="Contribute Key (optional)" Foreground="#888" FontSize="11" Margin="0,6,0,0"
                                               ToolTip.Tip="Shared token for contributing NPC voice overrides to the server. Leave empty for open LAN mode."/>
                                    <TextBox x:Name="ContributeKeyBox" TextChanged="OnContributeKeyChanged" PasswordChar="*"/>

                                    <TextBlock Text="Admin Key (optional)" Foreground="#888" FontSize="11" Margin="0,6,0,0"
                                               ToolTip.Tip="Admin token for pushing defaults to the server. Leave empty for open LAN mode."/>
                                    <TextBox x:Name="AdminKeyBox" TextChanged="OnAdminKeyChanged" PasswordChar="*"/>

                                    <CheckBox x:Name="ContributeByDefaultCheck"
                                              Content="Contribute NPC voice assignments to server automatically"
                                              FontSize="11" Margin="0,6,0,0"
                                              Click="OnContributeByDefaultChanged"
                                              ToolTip.Tip="When enabled, saving an NPC voice override pushes it to the server in the background to share with other players."/>

                                    <CheckBox x:Name="FirstLoadCompleteCheck"
                                              Content="First-load seeding complete (uncheck to re-seed from server)"
                                              FontSize="11" Margin="0,2,0,0"
                                              Click="OnFirstLoadCompleteChanged"
                                              ToolTip.Tip="On startup, if unchecked and a server URL is set, the app pulls server defaults for all four data types."/>

                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                        <Button x:Name="RemoteRefreshProvidersButton"
                                                Content="Refresh Remote Providers"
                                                Click="OnRefreshRemoteProvidersClicked"/>
                                        <TextBlock x:Name="RemoteProvidersStatus"
                                                   VerticalAlignment="Center"
                                                   Foreground="#888"
                                                   Text="Remote providers not loaded."/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <Expander x:Name="ExpanderPlayback"
                                      Header="Playback"
                                      HorizontalAlignment="Stretch"
                                      IsExpanded="False">
                                <StackPanel Margin="0,8,0,0" Spacing="6">
                                    <TextBlock Text="Speed" Foreground="#888" FontSize="11"/>
                                    <Slider x:Name="SpeedSlider"
                                            Minimum="75" Maximum="150" Value="100"
                                            ValueChanged="OnSpeedChanged"/>
                                    <TextBlock x:Name="SpeedLabel" Text="1.00×"
                                               Foreground="#888" FontSize="11" HorizontalAlignment="Right"/>

                                    <TextBlock Text="Playback Mode" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                                    <ComboBox x:Name="PlaybackModeSelector"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnPlaybackModeChanged">
                                        <ComboBoxItem Content="Wait for full text (default)" Tag="WaitForFullText"/>
                                        <ComboBoxItem Content="Stream on first chunk"        Tag="StreamOnFirstChunk"/>
                                    </ComboBox>

                                    <CheckBox x:Name="PhraseChunking"
                                              Content="Phrase chunking — split long text into sentences"
                                              IsChecked="True"
                                              Margin="0,4,0,0"
                                              Click="OnPhraseChunkingChanged"/>

                                    <TextBlock Text="Audio Output Device" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                                    <ComboBox x:Name="AudioDeviceSelector"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnAudioDeviceChanged"/>
                                </StackPanel>
                            </Expander>

                        </StackPanel>

                        <!-- RIGHT: Dialog Sources -->
                        <StackPanel Grid.Column="1" Spacing="6">

                            <Expander x:Name="ExpanderDialogSources"
                                      Header="Dialog Sources"
                                      HorizontalAlignment="Stretch"
                                      IsExpanded="False">
                                <StackPanel Margin="0,8,0,0" Spacing="6">
                                    <CheckBox x:Name="EnableGreeting"  Content="NPC Greeting / Gossip"       IsChecked="True"/>
                                    <CheckBox x:Name="EnableDetail"    Content="Quest Description"            IsChecked="True"/>
                                    <CheckBox x:Name="EnableProgress"  Content="Quest Progress"               IsChecked="True"/>
                                    <CheckBox x:Name="EnableReward"    Content="Quest Reward"                 IsChecked="True"/>
                                    <CheckBox x:Name="EnableBooks"     Content="In-game Books (experimental)" IsChecked="False"/>
                                </StackPanel>
                            </Expander>

                        </StackPanel>

                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Voice assignment tab -->
            <TabItem Header="Voices">
                <ScrollViewer>
                    <StackPanel Margin="12" Spacing="6">
                        <TextBlock Text="NPC Voice Profiles"
                                   FontWeight="SemiBold"
                                   FontSize="16"/>
                        <TextBlock Text="Choose how RuneReader should read text for each NPC type. These settings affect RuneReader speech only and do not change the game's own audio."
                                   TextWrapping="Wrap"
                                   Foreground="#888"
                                   FontSize="11"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Export Profiles"
                                    Click="OnVoicesExportClicked"/>
                            <Button Content="Import Profiles"
                                    Click="OnVoicesImportClicked"/>
                            <Button Content="Push to Server" FontSize="11"
                                    Click="OnVoicesPushToServerClicked"/>
                            <Button Content="Pull from Server" FontSize="11"
                                    Click="OnVoicesPullFromServerClicked"/>
                        </StackPanel>
                        <StackPanel x:Name="VoiceGrid" Spacing="6"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- NPC Overrides tab -->
            <TabItem Header="NPC Voices">
                <ScrollViewer>
                    <StackPanel Margin="12" Spacing="10">
                        <TextBlock Text="NPC Voice Overrides"
                                   Foreground="#4ECDC4" FontWeight="SemiBold"/>
                        <TextBlock Text="Assign a specific voice accent to any NPC by ID. Local overrides take priority over everything else. Server-sourced entries are read-only but can be shadowed with a local override."
                                   Foreground="#888" FontSize="11" TextWrapping="Wrap"/>

                        <!-- Rows populated in code-behind -->
                        <Grid x:Name="NpcOverridesGrid"
                              ColumnDefinitions="70,*,180,80,60,60"
                              HorizontalAlignment="Stretch"/>

                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button Content="Export JSON"
                                    FontSize="11"
                                    Click="OnNpcOverridesExportClicked"/>
                            <Button Content="Import JSON"
                                    FontSize="11"
                                    Click="OnNpcOverridesImportClicked"/>
                            <Button Content="Push to Server"
                                    FontSize="11"
                                    Click="OnNpcOverridesPushToServerClicked"/>
                            <Button Content="Pull from Server"
                                    FontSize="11"
                                    Click="OnNpcOverridesPullFromServerClicked"/>
                            <Button Content="Refresh"
                                    FontSize="11"
                                    Click="OnNpcOverridesRefreshClicked"/>
                            <TextBlock x:Name="NpcOverridesStatus"
                                       FontSize="11" Foreground="#888"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Advanced tab -->
            <TabItem Header="Advanced">
                <ScrollViewer>
                    <Grid Margin="12" ColumnDefinitions="*,*" ColumnSpacing="12">

                        <!-- LEFT: Capture, Playback, Cache -->
                        <StackPanel Grid.Column="0" Spacing="10">

                            <Expander x:Name="ExpanderCapture" Header="Capture" HorizontalAlignment="Stretch" IsExpanded="False">
                                <StackPanel Margin="0,8,0,0" Spacing="6" HorizontalAlignment="Stretch">
                                    <TextBlock Text="Capture Interval (ms)" Foreground="#888" FontSize="11"/>
                                    <NumericUpDown x:Name="CaptureInterval"
                                                   Minimum="1" Maximum="200" Value="5"
                                                   ValueChanged="OnCaptureIntervalChanged"/>

                                    <TextBlock Text="Rescan Interval (ms)" Foreground="#888" FontSize="11"/>
                                    <NumericUpDown x:Name="RescanInterval"
                                                   Minimum="1000" Maximum="30000" Value="5000"
                                                   ValueChanged="OnRescanIntervalChanged"/>
                                </StackPanel>
                            </Expander>

                            <Expander x:Name="ExpanderAdvPlayback" Header="Playback" HorizontalAlignment="Stretch" IsExpanded="False">
                                <StackPanel Margin="0,8,0,0" Spacing="6" HorizontalAlignment="Stretch">
                                    <CheckBox x:Name="RepeatSuppressionEnabled"
                                              Content="Suppress repeated speech"
                                              IsChecked="True"
                                              Click="OnRepeatSuppressionToggled"/>

                                    <TextBlock Text="Repeat suppression window (seconds)" Foreground="#888" FontSize="11"/>
                                    <NumericUpDown x:Name="RepeatSuppressionWindow"
                                                   Minimum="0" Maximum="60" Value="5"
                                                   ValueChanged="OnRepeatSuppressionWindowChanged"/>

                                    <TextBlock Text="If the same line is spoken again within this window, it is skipped. Set to 0 to disable timing while keeping the checkbox available."
                                               Foreground="#666" FontSize="10" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Expander>

                            <Expander x:Name="ExpanderCache" Header="Cache" HorizontalAlignment="Stretch" IsExpanded="False">
                                <StackPanel Margin="0,8,0,0" Spacing="6" HorizontalAlignment="Stretch">
                                    <CheckBox x:Name="CompressionEnabled"
                                              Content="Enable OGG compression"
                                              IsChecked="True"
                                              Click="OnCompressionToggled"/>

                                    <TextBlock Text="OGG Quality (0–10)" Foreground="#888" FontSize="11"/>
                                    <Slider x:Name="OggQualitySlider"
                                            Minimum="0" Maximum="10" Value="4"
                                            IsEnabled="{Binding #CompressionEnabled.IsChecked}"
                                            ValueChanged="OnOggQualityChanged"/>

                                    <TextBlock Text="Cache Size Limit (MB)" Foreground="#888" FontSize="11"/>
                                    <NumericUpDown x:Name="CacheSizeLimit"
                                                   Minimum="50" Maximum="10000" Value="500"
                                                   ValueChanged="OnCacheSizeLimitChanged"/>

                                    <CheckBox x:Name="SilenceTrim"
                                              Content="Silence trimming"
                                              IsChecked="True"
                                              Click="OnSilenceTrimToggled"/>

                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                        <TextBlock x:Name="CacheStatsLabel"
                                                   Text="Cache: 0 entries, 0 MB"
                                                   Foreground="#888" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <Button Content="Clear Cache"
                                                FontSize="11"
                                                Click="OnClearCacheClicked"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                        </StackPanel>

                        <!-- RIGHT: Audio, Piper, Diagnostics, Hotkey -->
                        <StackPanel Grid.Column="1" Spacing="10">

                            <Expander x:Name="ExpanderAudio" Header="Audio" HorizontalAlignment="Stretch" IsExpanded="False">
                                <StackPanel Margin="0,8,0,0" Spacing="6" HorizontalAlignment="Stretch">
                                    <TextBlock Text="Per-Accent-Group Volume Trim (dB)" Foreground="#888" FontSize="11"/>
                                    <StackPanel x:Name="VolumeTrimGrid" Spacing="4">
                                        <!-- Populated in code-behind from AccentGroup enum -->
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <Expander Header="Piper (Linux)" HorizontalAlignment="Stretch" x:Name="PiperSettings" IsVisible="False" IsExpanded="False">
                                <StackPanel Margin="0,8,0,0" Spacing="6" HorizontalAlignment="Stretch">
                                    <TextBlock Text="Piper Binary Path" Foreground="#888" FontSize="11"/>
                                    <TextBox x:Name="PiperBinaryPath"
                                             Watermark="/usr/bin/piper"
                                             TextChanged="OnPiperBinaryPathChanged"/>

                                    <TextBlock Text="Model Directory" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                                    <TextBox x:Name="PiperModelDir"
                                             Watermark="~/.local/share/piper/models"
                                             TextChanged="OnPiperModelDirChanged"/>

                                    <TextBlock Text="Installed Models" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                                    <ListBox x:Name="PiperModelList" Height="80"/>
                                    <TextBlock Text="Download models at github.com/rhasspy/piper"
                                               Foreground="#555" FontSize="10"/>
                                </StackPanel>
                            </Expander>

                            <Expander x:Name="ExpanderDiagnostics" Header="Diagnostics" HorizontalAlignment="Stretch" IsExpanded="False">
                                <StackPanel Margin="0,8,0,0" Spacing="6" HorizontalAlignment="Stretch">
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Last packet DIALOG"    Foreground="#888" FontSize="10" Margin="0,0,12,0"/>
                                        <TextBlock x:Name="DiagDialog"          Grid.Row="0" Grid.Column="1" Text="—" Foreground="#E0E0FF" FontSize="10"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Last synthesis latency" Foreground="#888" FontSize="10" Margin="0,3,12,0"/>
                                        <TextBlock x:Name="DiagLatency"         Grid.Row="1" Grid.Column="1" Text="—" Foreground="#E0E0FF" FontSize="10" Margin="0,3,0,0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Cache hit rate"         Foreground="#888" FontSize="10" Margin="0,3,12,0"/>
                                        <TextBlock x:Name="DiagHitRate"         Grid.Row="2" Grid.Column="1" Text="—" Foreground="#E0E0FF" FontSize="10" Margin="0,3,0,0"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Last decoded text"      Foreground="#888" FontSize="10" Margin="0,3,12,0" VerticalAlignment="Top"/>
                                        <TextBlock x:Name="DiagLastDecodedText" Grid.Row="3" Grid.Column="1" Text="—" Foreground="#FFD166" FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Processed text"         Foreground="#888" FontSize="10" Margin="0,3,12,0" VerticalAlignment="Top"/>
                                        <TextBlock x:Name="DiagProcessedText"   Grid.Row="4" Grid.Column="1" Text="—" Foreground="#B8E986" FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Text spoken"            Foreground="#888" FontSize="10" Margin="0,3,12,0" VerticalAlignment="Top"/>
                                        <TextBlock x:Name="DiagTextSpoken"      Grid.Row="5" Grid.Column="1" Text="—" Foreground="#88C0FF" FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <Expander x:Name="ExpanderHotkey" Header="Hotkey" HorizontalAlignment="Stretch" IsExpanded="False">
                                <StackPanel Margin="0,8,0,0" Spacing="6" HorizontalAlignment="Stretch">
                                    <TextBlock Text="Abort: ESC  (fixed — user-configurable in a future update)"
                                               Foreground="#888" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Expander>

                        </StackPanel>

                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Pronunciation">
                <ScrollViewer>
                    <Grid Margin="12" ColumnDefinitions="1.1*,0.9*" ColumnSpacing="12">

                        <!-- LEFT: workbench (unchanged) -->
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Pronunciation Workbench" Foreground="#4ECDC4" FontWeight="SemiBold"/>
                            <TextBlock Text="Use this to test Kokoro inline pronunciation hints before saving real rules."
                                       Foreground="#888" FontSize="11" TextWrapping="Wrap"/>

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Accent Group" Foreground="#888" FontSize="11"/>
                                    <ComboBox x:Name="PronAccentGroupSelector"
                                              SelectionChanged="OnPronunciationSelectionChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Gender / Slot" Foreground="#888" FontSize="11"/>
                                    <ComboBox x:Name="PronGenderSelector"
                                              SelectionChanged="OnPronunciationSelectionChanged">
                                        <ComboBoxItem Content="Male"     Tag="Male"/>
                                        <ComboBoxItem Content="Female"   Tag="Female"/>
                                        <ComboBoxItem Content="Narrator" Tag="Narrator"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="4">
                                    <TextBlock Text="Test Sentence" Foreground="#888" FontSize="11"/>
                                    <TextBox x:Name="PronTestSentence"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="72"
                                             Watermark="Stay away from Atal'zul, mon."
                                             TextChanged="OnPronunciationTextChanged"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Word / Phrase To Replace" Foreground="#888" FontSize="11"/>
                                    <TextBox x:Name="PronTargetText"
                                             Watermark="Atal'zul"
                                             TextChanged="OnPronunciationTextChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Phoneme Sounds" Foreground="#888" FontSize="11"/>
                                    <TextBox x:Name="PronPhonemeText"
                                             Watermark="ə tɑl zʊl"
                                             TextChanged="OnPronunciationTextChanged"/>
                                </StackPanel>
                            </Grid>

                            <WrapPanel Orientation="Horizontal" ItemWidth="130" ItemHeight="32">
                                <Button x:Name="PronSpeakOriginalButton"  Content="Speak Original"  Click="OnPronunciationSpeakOriginalClicked"/>
                                <Button x:Name="PronSpeakProcessedButton" Content="Speak Processed" Click="OnPronunciationSpeakProcessedClicked"/>
                                <Button x:Name="PronCopyPreviewButton"    Content="Copy Preview"    Click="OnPronunciationCopyPreviewClicked"/>
                                <Button x:Name="PronClearButton"          Content="Clear"           Click="OnPronunciationClearClicked"/>
                            </WrapPanel>

                            <Separator Margin="0,4"/>
                            <TextBlock Text="Sound Picker" Foreground="#4ECDC4" FontWeight="SemiBold"/>
                            <TextBlock Text="All non-US-keyboard symbols used by the workbench should be inserted from here."
                                       Foreground="#888" FontSize="11" TextWrapping="Wrap"/>

                            <ScrollViewer MaxHeight="260" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="8">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Stress / Timing" Foreground="#88C0FF" FontSize="11" FontWeight="SemiBold"/>
                                        <WrapPanel x:Name="PronStressTimingGrid"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Diphthongs" Foreground="#88C0FF" FontSize="11" FontWeight="SemiBold"/>
                                        <WrapPanel x:Name="PronDiphthongGrid"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Vowels" Foreground="#88C0FF" FontSize="11" FontWeight="SemiBold"/>
                                        <WrapPanel x:Name="PronVowelGrid"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Consonants" Foreground="#88C0FF" FontSize="11" FontWeight="SemiBold"/>
                                        <WrapPanel x:Name="PronConsonantGrid"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <Border Background="#0F3460" CornerRadius="6" Padding="10">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="PronSymbolTitle"       Text="Select a sound symbol"              Foreground="#E0E0FF" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="PronSymbolDescription" Text="Descriptions and examples appear here." Foreground="#C0C0D0" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="PronSymbolExample"     Text=""                                   Foreground="#FFD166" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#101A2B" CornerRadius="6" Padding="10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Lookalikes / Quick Help"               Foreground="#E0E0FF" FontWeight="SemiBold"/>
                                    <TextBlock Text=": is a normal colon. ː is the IPA length mark."   Foreground="#C0C0D0" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text="' is an apostrophe. ˈ is primary stress."         Foreground="#C0C0D0" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text=", is a comma. ˌ is secondary stress."             Foreground="#C0C0D0" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text="g is ASCII g. ɡ is the IPA hard-g symbol."        Foreground="#C0C0D0" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Separator Margin="0,4"/>
                            <TextBlock Text="Preview" Foreground="#4ECDC4" FontWeight="SemiBold"/>

                            <TextBlock Text="Original" Foreground="#888" FontSize="11"/>
                            <TextBox x:Name="PronOriginalPreview"
                                     Text="—" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                     Background="#0F3460" Foreground="#E0E0FF"/>

                            <TextBlock Text="Processed / Kokoro Markup" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                            <TextBox x:Name="PronProcessedPreview"
                                     Text="—" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                     Background="#0F3460" Foreground="#FFD166"/>
                        </StackPanel>

                        <!-- RIGHT: saved rules list + rule authoring controls -->
                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Saved Rules" Foreground="#4ECDC4" FontWeight="SemiBold"/>
                            <TextBlock Text="Select a rule to load it into the workbench for editing."
                                       Foreground="#888" FontSize="11" TextWrapping="Wrap"/>

                            <ListBox x:Name="PronRuleList"
                                     Height="180"
                                     SelectionChanged="OnPronunciationRuleListSelectionChanged"/>

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Scope" Foreground="#888" FontSize="11"/>
                                    <ComboBox x:Name="PronRuleScopeSelector"
                                              SelectionChanged="OnPronunciationRuleSelectionChanged">
                                        <ComboBoxItem Content="Global"       Tag="Global"/>
                                        <ComboBoxItem Content="Accent Group" Tag="AccentGroup"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Rule Accent Group" Foreground="#888" FontSize="11"/>
                                    <ComboBox x:Name="PronRuleAccentGroupSelector"
                                              SelectionChanged="OnPronunciationRuleSelectionChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12">
                                    <CheckBox x:Name="PronRuleWholeWord"     Content="Whole word"    IsChecked="True"  Click="OnPronunciationRuleClickChanged"/>
                                    <CheckBox x:Name="PronRuleCaseSensitive" Content="Case sensitive" IsChecked="False" Click="OnPronunciationRuleClickChanged"/>
                                    <CheckBox x:Name="PronRuleEnabled"       Content="Enabled"       IsChecked="True"  Click="OnPronunciationRuleClickChanged"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Notes" Foreground="#888" FontSize="11"/>
                            <TextBox x:Name="PronRuleNotes"
                                     Watermark="Optional note, such as how the name should sound."
                                     TextChanged="OnPronunciationRuleTextChanged"/>

                            <WrapPanel Orientation="Horizontal" ItemWidth="120" ItemHeight="32">
                                <Button x:Name="PronSaveRuleButton"   Content="Save Rule"    Click="OnPronunciationSaveRuleClicked"/>
                                <Button x:Name="PronDeleteRuleButton" Content="Delete Rule"  Click="OnPronunciationDeleteRuleClicked"/>
                                <Button x:Name="PronReloadRulesButton" Content="Reload Rules" Click="OnPronunciationReloadRulesClicked"/>
                                <Button x:Name="PronExportRulesButton" Content="Export Rules" Click="OnPronunciationExportRulesClicked"/>
                                <Button x:Name="PronImportRulesButton" Content="Import Rules" Click="OnPronunciationImportRulesClicked"/>
                                <Button x:Name="PronPushToServerButton"   Content="Push to Server"   Click="OnPronunciationPushToServerClicked"/>
                                <Button x:Name="PronPullFromServerButton" Content="Pull from Server" Click="OnPronunciationPullFromServerClicked"/>
                            </WrapPanel>

                            <TextBlock x:Name="PronRuleStatus"
                                       Text="Rules stored in runereader-voice.db."
                                       Foreground="#888"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Text Shaping">
                <ScrollViewer>
                    <Grid Margin="12" ColumnDefinitions="1.1*,0.9*" ColumnSpacing="12">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Text Shaping Workbench" Foreground="#4ECDC4" FontWeight="SemiBold"/>
                            <TextBlock Text="Apply simple text swaps before pronunciation rules. This is best for pause shaping, contemplation dots, and light phrasing cleanup."
                                       Foreground="#888" FontSize="11" TextWrapping="Wrap"/>

                            <TextBlock Text="Original Text" Foreground="#888" FontSize="11"/>
                            <TextBox x:Name="TextSwapOriginalText"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="84"
                                     Watermark="Wait... I know what to do - give me a moment."
                                     TextChanged="OnTextSwapTextChanged"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Find Text" Foreground="#888" FontSize="11"/>
                                    <TextBox x:Name="TextSwapFindText"
                                             Watermark=" - "
                                             TextChanged="OnTextSwapTextChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Replace With" Foreground="#888" FontSize="11"/>
                                    <TextBox x:Name="TextSwapReplaceText"
                                             Watermark=" ... "
                                             TextChanged="OnTextSwapTextChanged"/>
                                    <CheckBox x:Name="TextSwapReplaceWithCrLf"
                                              Margin="0,6,0,0"
                                              Content="Replace with new line (CR/LF)"
                                              IsChecked="False"
                                              Click="OnTextSwapClickChanged"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,140" ColumnSpacing="12" VerticalAlignment="Center">
                                <CheckBox Grid.Column="0"
                                          x:Name="TextSwapWholeWord"
                                          Content="Whole word"
                                          IsChecked="False"
                                          Click="OnTextSwapClickChanged"/>
                                <CheckBox Grid.Column="1"
                                          x:Name="TextSwapCaseSensitive"
                                          Content="Case sensitive"
                                          IsChecked="False"
                                          Click="OnTextSwapClickChanged"/>
                                <CheckBox Grid.Column="2"
                                          x:Name="TextSwapEnabled"
                                          Content="Enabled"
                                          IsChecked="True"
                                          Click="OnTextSwapClickChanged"/>
                                <TextBlock Grid.Column="3"
                                           Text="Priority"
                                           Foreground="#888"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                                <NumericUpDown Grid.Column="4"
                                               x:Name="TextSwapPriority"
                                               Minimum="0"
                                               Maximum="1000"
                                               Value="100"
                                               HorizontalAlignment="Stretch"
                                               ValueChanged="OnTextSwapPriorityChanged"/>
                            </Grid>

                            <TextBlock Text="Preview" Foreground="#4ECDC4" FontWeight="SemiBold" Margin="0,4,0,0"/>

                            <TextBlock Text="Original" Foreground="#888" FontSize="11"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0"
                                         x:Name="TextSwapOriginalPreview"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Background="#0F3460"
                                         Foreground="#E0E0FF"/>
                                <Button Grid.Column="1"
                                        x:Name="TextSwapSpeakOriginalButton"
                                        Content="Speak"
                                        MinWidth="72"
                                        Click="OnTextSwapSpeakOriginalClicked"/>
                            </Grid>

                            <TextBlock Text="After Text Shaping" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0"
                                         x:Name="TextSwapProcessedPreview"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Background="#0F3460"
                                         Foreground="#FFD166"/>
                                <Button Grid.Column="1"
                                        x:Name="TextSwapSpeakProcessedButton"
                                        Content="Speak"
                                        MinWidth="72"
                                        Click="OnTextSwapSpeakProcessedClicked"/>
                            </Grid>

                            <TextBlock Text="Final TTS Text" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0"
                                         x:Name="TextSwapFinalPreview"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Background="#0F3460"
                                         Foreground="#B8E986"/>
                                <Button Grid.Column="1"
                                        x:Name="TextSwapSpeakFinalButton"
                                        Content="Speak"
                                        MinWidth="72"
                                        Click="OnTextSwapSpeakFinalClicked"/>
                            </Grid>

                            <Button x:Name="TextSwapCopyPreviewButton"
                                    Content="Copy Final Preview"
                                    HorizontalAlignment="Left"
                                    Click="OnTextSwapCopyPreviewClicked"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Saved Rules" Foreground="#4ECDC4" FontWeight="SemiBold"/>
                            <TextBlock Text="Use saved rules for reusable pause and phrasing cleanup. Rules are applied before pronunciation processing."
                                       Foreground="#888" FontSize="11" TextWrapping="Wrap"/>

                            <ListBox x:Name="TextSwapRuleList"
                                     Height="180"
                                     SelectionChanged="OnTextSwapRuleSelectionChanged"/>

                            <TextBlock Text="Notes" Foreground="#888" FontSize="11"/>
                            <TextBox x:Name="TextSwapRuleNotes"
                                     Watermark="Optional note, such as why this phrasing works better."
                                     TextChanged="OnTextSwapTextChanged"/>

                            <WrapPanel Orientation="Horizontal" ItemWidth="120" ItemHeight="32">
                                <Button x:Name="TextSwapNewRuleButton"    Content="New Rule"       Click="OnTextSwapNewRuleClicked"/>
                                <Button x:Name="TextSwapSaveRuleButton"   Content="Save Rule"      Click="OnTextSwapSaveRuleClicked"/>
                                <Button x:Name="TextSwapDeleteRuleButton" Content="Delete Rule"    Click="OnTextSwapDeleteRuleClicked"/>
                                <Button x:Name="TextSwapReloadRulesButton"   Content="Reload Rules"    Click="OnTextSwapReloadRulesClicked"/>
                                <Button x:Name="TextSwapExportRulesButton"   Content="Export Rules"    Click="OnTextSwapExportRulesClicked"/>
                                <Button x:Name="TextSwapImportRulesButton"   Content="Import Rules"    Click="OnTextSwapImportRulesClicked"/>
                                <Button x:Name="TextSwapPushToServerButton"   Content="Push to Server"   Click="OnTextSwapPushToServerClicked"/>
                                <Button x:Name="TextSwapPullFromServerButton" Content="Pull from Server" Click="OnTextSwapPullFromServerClicked"/>
                            </WrapPanel>

                            <Border Background="#101A2B" CornerRadius="6" Padding="10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Suggested uses" Foreground="#E0E0FF" FontWeight="SemiBold"/>
                                    <TextBlock Text="• turn ' - ' into a pause like ' ... ' or ', '"
                                               Foreground="#C0C0D0" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text="• add breathing space after ellipses or punctuation"
                                               Foreground="#C0C0D0" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text="• swap a small phrase when pronunciation markup would be overkill"
                                               Foreground="#C0C0D0" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="TextSwapRuleStatus"
                                       Text="Rules save into config/text-swap-rules.json."
                                       Foreground="#888"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            </TabControl>
        </Expander>

    </Grid>

</Window>
