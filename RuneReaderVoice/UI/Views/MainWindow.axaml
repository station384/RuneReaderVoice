<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="RuneReaderVoice.UI.Views.MainWindow"
        Title="RuneReader Voice"
        Width="560" Height="680"
        MinWidth="480" MinHeight="500"
        Background="#1A1A2E">

    <DockPanel>

        <!-- ── Title bar ──────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#16213E" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="RuneReader Voice"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#E0E0FF" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusBadge"
                           Text="●  Idle"
                           FontSize="13" Foreground="#888"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Live status panel ──────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="#0F3460" Margin="8,8,8,0"
                CornerRadius="6" Padding="12,10">
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">

                <!-- Capture status -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Capture" Foreground="#888" FontSize="11"/>
                <TextBlock x:Name="CaptureStatus" Grid.Row="0" Grid.Column="1"
                           Text="Stopped" Foreground="#FF6B6B" FontSize="11"/>

                <!-- Session status -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Session" Foreground="#888" FontSize="11" Margin="0,4,0,0"/>
                <TextBlock x:Name="SessionStatus" Grid.Row="1" Grid.Column="1"
                           Text="—" Foreground="#E0E0FF" FontSize="11" Margin="0,4,0,0"/>

                <!-- Playback state -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Playback" Foreground="#888" FontSize="11" Margin="0,4,0,0"/>
                <TextBlock x:Name="PlaybackStatus" Grid.Row="2" Grid.Column="1"
                           Text="Idle" Foreground="#4ECDC4" FontSize="11" Margin="0,4,0,0"/>

                <!-- Cache hit indicator -->
                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="Cache" Foreground="#888" FontSize="11" Margin="0,4,0,0"/>
                <TextBlock x:Name="CacheStatus" Grid.Row="3" Grid.Column="1"
                           Text="—" Foreground="#FFD166" FontSize="11" Margin="0,4,0,0"/>
            </Grid>
        </Border>

        <!-- ── Start / Stop button ────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Margin="8,8,8,0">
            <Button x:Name="StartStopButton"
                    Content="Start Capture"
                    HorizontalAlignment="Stretch"
                    Height="36"
                    Background="#E94560"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Click="OnStartStopClicked"/>
        </Border>

        <!-- ── Settings tabs ──────────────────────────────────────────── -->
        <TabControl DockPanel.Dock="Bottom"
                    Margin="8,8,8,8"
                    Background="#16213E">

            <!-- Basic settings tab -->
            <TabItem Header="Settings">
                <ScrollViewer>
                    <StackPanel Margin="12" Spacing="10">

                        <TextBlock Text="TTS Provider" Foreground="#888" FontSize="11"/>
                        <ComboBox x:Name="ProviderSelector"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnProviderChanged"/>

                        <TextBlock Text="Volume" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                        <Slider x:Name="VolumeSlider"
                                Minimum="0" Maximum="100" Value="80"
                                ValueChanged="OnVolumeChanged"/>

                        <TextBlock Text="Playback Speed" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                        <Slider x:Name="SpeedSlider"
                                Minimum="75" Maximum="150" Value="100"
                                ValueChanged="OnSpeedChanged"/>
                        <TextBlock x:Name="SpeedLabel" Text="1.00×"
                                   Foreground="#888" FontSize="11" HorizontalAlignment="Right"/>

                        <TextBlock Text="Playback Mode" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                        <ComboBox x:Name="PlaybackModeSelector"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnPlaybackModeChanged">
                            <ComboBoxItem Content="Wait for full text (default)" Tag="WaitForFullText"/>
                            <ComboBoxItem Content="Stream on first chunk"        Tag="StreamOnFirstChunk"/>
                        </ComboBox>

                        <CheckBox x:Name="PhraseChunking"
                                  Content="Phrase chunking — split text into sentences for lower latency (Kokoro only)"
                                  IsChecked="True"
                                  Margin="0,4,0,0"
                                  Click="OnPhraseChunkingChanged"/>

                        <TextBlock Text="Audio Output Device" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                        <ComboBox x:Name="AudioDeviceSelector"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnAudioDeviceChanged"/>

                        <Separator Margin="0,8"/>

                        <TextBlock Text="Dialog Sources" Foreground="#888" FontSize="11"/>
                        <CheckBox x:Name="EnableGreeting"  Content="NPC Greeting / Gossip" IsChecked="True"/>
                        <CheckBox x:Name="EnableDetail"    Content="Quest Description"     IsChecked="True"/>
                        <CheckBox x:Name="EnableProgress"  Content="Quest Progress"        IsChecked="True"/>
                        <CheckBox x:Name="EnableReward"    Content="Quest Reward"          IsChecked="True"/>
                        <CheckBox x:Name="EnableBooks"     Content="In-game Books (experimental)" IsChecked="False"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Voice assignment tab -->
            <TabItem Header="Voices">
                <ScrollViewer>
                    <StackPanel x:Name="VoiceGrid" Margin="12" Spacing="6">
                        <!-- Populated in code-behind from AccentGroup enum + provider voices -->
                        <TextBlock Text="Voice assignments load after provider selection."
                                   Foreground="#888" FontSize="11"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Advanced tab -->
            <TabItem Header="Advanced">
                <ScrollViewer>
                    <StackPanel Margin="12" Spacing="10">

                        <TextBlock Text="Capture" Foreground="#4ECDC4" FontWeight="SemiBold"/>

                        <TextBlock Text="Capture Interval (ms)" Foreground="#888" FontSize="11"/>
                        <NumericUpDown x:Name="CaptureInterval"
                                       Minimum="1" Maximum="200" Value="5"
                                       ValueChanged="OnCaptureIntervalChanged"/>

                        <TextBlock Text="Rescan Interval (ms)" Foreground="#888" FontSize="11"/>
                        <NumericUpDown x:Name="RescanInterval"
                                       Minimum="1000" Maximum="30000" Value="5000"
                                       ValueChanged="OnRescanIntervalChanged"/>

                        <Separator Margin="0,8"/>
                        <TextBlock Text="Cache" Foreground="#4ECDC4" FontWeight="SemiBold"/>

                        <CheckBox x:Name="CompressionEnabled"
                                  Content="Enable OGG compression"
                                  IsChecked="True"
                                  Click="OnCompressionToggled"/>

                        <TextBlock Text="OGG Quality (0–10)" Foreground="#888" FontSize="11"/>
                        <Slider x:Name="OggQualitySlider"
                                Minimum="0" Maximum="10" Value="4"
                                IsEnabled="{Binding #CompressionEnabled.IsChecked}"
                                ValueChanged="OnOggQualityChanged"/>

                        <TextBlock Text="Cache Size Limit (MB)" Foreground="#888" FontSize="11"/>
                        <NumericUpDown x:Name="CacheSizeLimit"
                                       Minimum="50" Maximum="10000" Value="500"
                                       ValueChanged="OnCacheSizeLimitChanged"/>

                        <CheckBox x:Name="SilenceTrim"
                                  Content="Silence trimming"
                                  IsChecked="True"
                                  Click="OnSilenceTrimToggled"/>

                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <TextBlock x:Name="CacheStatsLabel"
                                       Text="Cache: 0 entries, 0 MB"
                                       Foreground="#888" FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Button Content="Clear Cache"
                                    FontSize="11"
                                    Click="OnClearCacheClicked"/>
                        </StackPanel>

                        <Separator Margin="0,8"/>
                        <TextBlock Text="Audio" Foreground="#4ECDC4" FontWeight="SemiBold"/>

                        <TextBlock Text="Per-Accent-Group Volume Trim (dB)" Foreground="#888" FontSize="11"/>
                        <StackPanel x:Name="VolumeTrimGrid" Spacing="4">
                            <!-- Populated in code-behind from AccentGroup enum -->
                        </StackPanel>

                        <!-- Linux-only: Piper settings -->
                        <StackPanel x:Name="PiperSettings" IsVisible="False">
                            <Separator Margin="0,8"/>
                            <TextBlock Text="Piper (Linux)" Foreground="#4ECDC4" FontWeight="SemiBold"/>

                            <TextBlock Text="Piper Binary Path" Foreground="#888" FontSize="11"/>
                            <TextBox x:Name="PiperBinaryPath"
                                     Watermark="/usr/bin/piper"
                                     TextChanged="OnPiperBinaryPathChanged"/>

                            <TextBlock Text="Model Directory" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                            <TextBox x:Name="PiperModelDir"
                                     Watermark="~/.local/share/piper/models"
                                     TextChanged="OnPiperModelDirChanged"/>

                            <TextBlock Text="Installed Models" Foreground="#888" FontSize="11" Margin="0,6,0,0"/>
                            <ListBox x:Name="PiperModelList" Height="80"/>
                            <TextBlock Text="Download models at github.com/rhasspy/piper"
                                       Foreground="#555" FontSize="10"/>
                        </StackPanel>

                        <Separator Margin="0,8"/>
                        <TextBlock Text="Diagnostics" Foreground="#4ECDC4" FontWeight="SemiBold"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Last packet DIALOG" Foreground="#888" FontSize="10" Margin="0,0,12,0"/>
                            <TextBlock x:Name="DiagDialog" Grid.Row="0" Grid.Column="1" Text="—" Foreground="#E0E0FF" FontSize="10"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Last synthesis latency" Foreground="#888" FontSize="10" Margin="0,3,12,0"/>
                            <TextBlock x:Name="DiagLatency" Grid.Row="1" Grid.Column="1" Text="—" Foreground="#E0E0FF" FontSize="10" Margin="0,3,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Cache hit rate" Foreground="#888" FontSize="10" Margin="0,3,12,0"/>
                            <TextBlock x:Name="DiagHitRate" Grid.Row="2" Grid.Column="1" Text="—" Foreground="#E0E0FF" FontSize="10" Margin="0,3,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Last decoded text" Foreground="#888" FontSize="10" Margin="0,3,12,0" VerticalAlignment="Top"/>
                            <TextBlock x:Name="DiagLastText" Grid.Row="3" Grid.Column="1" Text="—" Foreground="#FFD166" FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap"/>
                        </Grid>

                        <TextBlock Text="Hotkey" Foreground="#4ECDC4" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <TextBlock Text="Abort: ESC  (fixed — user-configurable in a future update)"
                                   Foreground="#888" FontSize="11"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

    </DockPanel>

</Window>
